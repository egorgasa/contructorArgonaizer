# Copy this file to `.env` and fill in real values. Never commit `.env`.

# PostgreSQL connection string. Local development can use a local PostgreSQL
# database; production MUST use a managed PostgreSQL connection string
# (Neon / Supabase / Vercel Postgres / RDS, etc.).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Shared password for the admin area. If left empty, /admin is OPEN
# (handy for local dev; MUST be set to a strong value in production).
ADMIN_PASSWORD="change-me"

# File storage backend for request attachments.
#   "local"       — local filesystem (dev default; NOT durable on serverless)
#   "vercel-blob" — Vercel Blob (production-safe durable storage)
# If unset and BLOB_READ_WRITE_TOKEN is present, Vercel Blob is used.
FILE_STORAGE_DRIVER="local"

# Vercel Blob read-write token. Required when FILE_STORAGE_DRIVER="vercel-blob".
# Provided automatically by Vercel when a Blob store is attached to the project.
# Leave empty for local filesystem development. Never commit a real token.
BLOB_READ_WRITE_TOKEN=""

# Optional: override where the LOCAL storage backend places uploaded files.
# Defaults to <cwd>/uploads relative to the running process. Only used when
# FILE_STORAGE_DRIVER="local".
UPLOADS_DIR="./uploads"
